{
  "name": "PartySupply",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "PartySupply"
  },
  "runtimes": [
    {
      "name": "PartySupplyAgent",
      "build": "Container",
      "entrypoint": "agent.ts",
      "codeLocation": "agent/",
      "runtimeVersion": "NODE_20",
      "networkMode": "PUBLIC",
      "protocol": "HTTP",
      "envVars": [
        { "name": "AWS_REGION", "value": "us-west-2" },
        { "name": "VECTOR_BUCKET_NAME", "value": "party-supply-vectors" },
        { "name": "MEMORY_NAME", "value": "PartySupplyMemory" }
      ]
    }
  ],
  "memories": [
    {
      "name": "PartySupplyMemory",
      "eventExpiryDuration": 30,
      "strategies": [
        {
          "type": "SEMANTIC",
          "name": "FactExtractor",
          "namespaces": ["/facts/{actorId}/"]
        },
        {
          "type": "SUMMARIZATION",
          "name": "SessionSummarizer",
          "namespaces": ["/summaries/{actorId}/{sessionId}/"]
        },
        {
          "type": "USER_PREFERENCE",
          "name": "PreferenceLearner",
          "namespaces": ["/preferences/{actorId}/"]
        }
      ]
    }
  ],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [
    {
      "name": "PartySupplyGateway",
      "description": "Gateway for the Party Supply Chat Agent with IAM auth",
      "authorizerType": "AWS_IAM",
      "targets": []
    }
  ],
  "policyEngines": [],
  "configBundles": [],
  "abTests": [],
  "httpGateways": []
}
