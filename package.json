{
  "name": "party-supply-chat-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Lightweight chat agent with Bedrock AgentCore, Strands SDK, and S3 RAG",
  "scripts": {
    "install:all": "npm install && cd agent && npm install && cd ../chat-ui && npm install",
    "generate-data": "npx tsx scripts/generate-seed-data.ts",
    "deploy": "./scripts/deploy.sh",
    "dev:agent": "cd agent && npm run dev",
    "dev:ui": "cd chat-ui && npm run dev"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agentcore": "^3.1047.0",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@aws-sdk/client-s3vectors": "^3.700.0"
  }
}
